generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  username        String   @unique
  xp              Int      @default(0)
  level           Int      @default(1)
  avatarKitId     String?
  hasSeenTutorial Boolean  @default(false)
  createdAt       DateTime @default(now())
  scores          Score[]
  shots           Shot[]
}

model Score {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  goalsScored Int
  totalShots  Int      @default(5)
  difficulty  String
  xpEarned    Int
  createdAt   DateTime @default(now())
}

model Shot {
  id        String   @id @default(uuid())
  playerId  String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  x         Float
  y         Float
  power     Int
  scored    Boolean
  prevX     Float?
  prevY     Float?
  createdAt DateTime @default(now())

  @@index([playerId])
  @@index([userId])
}
